{
  "name": "smanunion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:core": "bun run --cwd packages/core dev",
    "dev:web": "bun run --cwd packages/web dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:core": "bun run --cwd packages/core test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "prettier": "^3.6.0"
  },
  "packageManager": "bun@1.3.9"
}
