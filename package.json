{
  "name": "smanbase",
  "version": "26.4.21",
  "private": true,
  "type": "module",
  "main": "electron/dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx server/index.ts",
    "build": "vite build && tsc -p server/tsconfig.json && node -e \"require('fs').writeFileSync('dist/server/package.json',JSON.stringify({type:'module'},null,2))\" && node -e \"require('fs').cpSync('server/init/templates','dist/server/server/init/templates',{recursive:true})\"",
    "build:electron": "electron-vite build",
    "electron:dev": "electron-vite dev",
    "electron:build": "pnpm build && pnpm build:electron && electron-builder",
    "init:skills": "tsx scripts/init-skills.ts",
    "init:system": "tsx scripts/init-system.ts",
    "postinstall": "node scripts/patch-sdk.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.121",
    "@anthropic-ai/claude-code": "2.1.121",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@streamdown/code": "^1.1.1",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "express": "^4.21.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.0.1",
    "node-cron": "^4.2.1",
    "qrcode": "^1.5.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.7.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "wait-on": "^9.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "electron"
    ]
  },
  "build": {
    "appId": "com.smanbase.app",
    "productName": "Sman",
    "icon": "build/icon.ico",
    "files": [
      "dist/**/*",
      "electron/dist/**/*",
      "node_modules/**/*",
      "!node_modules/.pnpm/**/vendor/**/x64-darwin",
      "!node_modules/.pnpm/**/vendor/**/x64-darwin/**/*",
      "!node_modules/.pnpm/**/vendor/**/arm64-darwin",
      "!node_modules/.pnpm/**/vendor/**/arm64-darwin/**/*",
      "!node_modules/.pnpm/**/vendor/**/x64-linux",
      "!node_modules/.pnpm/**/vendor/**/x64-linux/**/*",
      "!node_modules/.pnpm/**/vendor/**/arm64-linux",
      "!node_modules/.pnpm/**/vendor/**/arm64-linux/**/*",
      "!node_modules/.pnpm/**/vendor/**/arm64-win32",
      "!node_modules/.pnpm/**/vendor/**/arm64-win32/**/*",
      "!node_modules/.pnpm/**/@img/**/*",
      "!node_modules/.pnpm/**/sharp-win32-arm64/**/*",
      "!node_modules/.pnpm/**/@rollup/**/*",
      "!node_modules/.pnpm/**/esbuild/**/*",
      "!node_modules/.pnpm/**/prebuild-install/**/*",
      "!node_modules/.pnpm/**/node-gyp/**/*",
      "!node_modules/.pnpm/**/cmake-js/**/*",
      "!node_modules/.pnpm/**/source-map/**/*",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/README*",
      "!node_modules/**/readme*",
      "!node_modules/**/.eslintrc*",
      "!node_modules/**/.prettierrc*",
      "!node_modules/**/tsconfig.json",
      "!node_modules/**/.github/**/*",
      "!node_modules/**/test/**/*",
      "!node_modules/**/tests/**/*",
      "!node_modules/**/__tests__/**/*",
      "!node_modules/**/docs/**/*",
      "plugins/**/*",
      "!plugins/office-skills/venv/**/*",
      "!plugins/office-skills/node_modules/**/*",
      "!plugins/office-skills/.git/**/*",
      "!plugins/office-skills/outputs/**/*",
      "!plugins/gstack/browse/**/*",
      "!plugins/gstack/bin/**/*",
      "!plugins/gstack/node_modules/**/*",
      "!plugins/gstack/.git/**/*",
      "!plugins/gstack/docs/**/*",
      "!plugins/gstack/test/**/*",
      "!plugins/gstack/scripts/**/*",
      "!plugins/gstack/canary/**/*",
      "!plugins/gstack/benchmark/**/*",
      "!plugins/gstack/supabase/**/*",
      "public/**/*",
      "scripts/patch-sdk.mjs"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "Sman-Setup-${version}.${ext}",
      "sign": false,
      "signingHashAlgorithms": []
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "allowElevation": true
    },
    "forceCodeSigning": false,
    "asar": true,
    "asarUnpack": [
      "node_modules/.pnpm/better-sqlite3@*/node_modules/better-sqlite3/**/*",
      "node_modules/better-sqlite3/**/*",
      "plugins/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
